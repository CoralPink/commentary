{
  "imports": {
    "plyr": "npm:plyr@3.8.4",
    "rolldown": "npm:rolldown@1.0.2",

    "vitest": "npm:vitest@4.1.7",
    "@vitest/coverage-v8": "npm:@vitest/coverage-v8@4.1.7",
    "happy-dom": "npm:happy-dom@20.9.0"
  },
  "tasks": {
    "bundle": "rolldown -c",
    "serve": "deno run --allow-net --allow-read --allow-sys=networkInterfaces jsr:@std/http/file-server ../",

    "test": "vitest",
    "test:ci": "vitest run --coverage"
  },
  "compilerOptions": {
    "lib": ["deno.window", "esnext", "dom", "dom.iterable", "webworker"],
    "module": "esnext",

    "moduleResolution": "bundler",

    "strict": true,
    "noFallthroughCasesInSwitch": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Code cleanliness / Lint-like flags
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    // Improved code predictability and consistency
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true
  },
  "lint": {
    "exclude": ["dist/"]
  },
  "nodeModulesDir": "auto" // You will likely need it when using Vitest.
}
