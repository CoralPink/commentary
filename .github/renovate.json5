{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",

    // Require Dependency Dashboard approval for major updates.
    ":approveMajorUpdates",

    // Do not separate patch and minor upgrades into separate PRs for the same dependency.
    ":combinePatchMinorReleases",

    // Automerge patch and minor upgrades if they pass tests.
    ":automergeMinor",
    // Automerge digest upgrades if they pass tests.
    ":automergeDigest",

    // Run lock file maintenance (updates) early Monday mornings.
    ":maintainLockFilesWeekly",

    // Preserve (but continue to upgrade) any existing SemVer ranges.
    ":preserveSemverRanges",

    // Custom Manager Presets
    "customManagers:githubActionsVersions",
    "customManagers:biomeVersions",
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchFileNames": ["rs/mdbook-footnote/**"],
      "groupName": "cargo(backend)",
    },
    {
      "matchManagers": ["cargo"],
      "matchFileNames": ["rs/wasm/**"],
      "groupName": "cargo(wasm)",
    },
    {
      "matchManagers": ["deno"],
      "matchFileNames": ["js/**"],
      "groupName": "deno(frontend)",
    },
    {
      "matchManagers": ["deno"],
      "matchFileNames": ["scripts/**"],
      "groupName": "deno(backend)",
    },
    {
      "matchManagers": ["deno"],
      "matchFileNames": ["scss/**"],
      "groupName": "deno(scss)",
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest"],
      "schedule": ["before 4am on monday"],
    },
    {
      "matchManagers": ["pep621"],
      "matchFileNames": ["fonts/**"],
      "groupName": "uv(fonts)",
    },
  ],
  "timezone": "Asia/Tokyo",
}
