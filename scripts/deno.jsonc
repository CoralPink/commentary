{
  "imports": {
    "cheerio": "npm:cheerio@1.2.0",
    "cheerio/utils": "npm:cheerio@1.2.0/utils",
    "jsdom": "npm:jsdom@29.1.1",
    "js-beautify": "npm:js-beautify@1.15.4",
    "path": "jsr:@std/path@1.1.5",
    "p-limit": "npm:p-limit@7.3.0"
  },
  "tasks": {
    "link": "deno run --allow-read --allow-write link.ts $DEBUG",
    "pagelist": "deno run --allow-read --allow-write pagelist.ts $DEBUG",
    "json": "deno run --allow-read --allow-write json.ts",

    "regenerate": {
      "dependencies": ["link", "pagelist", "json"]
    }
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom"]
  },
  "nodeModulesDir": "none"
}
